+    // For iOS we normally hardcode the inifile as "rc" in the .app directory,
+    // but honor explicit overrides so that embedders (e.g. LibreOfficeKit
+    // consumers) can relocate fundamentalrc/unorc outside the .app bundle.
+    OUString aBootstrapOverride;
+    if (!rtl::Bootstrap::get(u"URE_BOOTSTRAP"_ustr, aBootstrapOverride) || aBootstrapOverride.isEmpty())
+    {
+        rtl::Bootstrap::setIniFilename(aAppProgramURL + "/" SAL_CONFIGFILE("fundamental"));
+    }
+    OUString aUnoIniOverride;
+    if (rtl::Bootstrap::get(u"URE_UNO_INI_URI"_ustr, aUnoIniOverride) && !aUnoIniOverride.isEmpty())
+    {
+        // Fall through to the no-arg overload so that getUnoIniUri() (and
+        // thus the URE_UNO_INI_URI override) is honored.
+        xContext = cppu::defaultBootstrap_InitialComponentContext();
+    }
+    else
+    {
+        xContext = cppu::defaultBootstrap_InitialComponentContext(aAppProgramURL + "/rc");
+    }
 #elif defined MACOSX
