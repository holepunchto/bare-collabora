{
  "name": "bare-collabora",
  "version": "0.1.0",
  "description": "Collabora bindings for Bare",
  "exports": {
    "./package": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "imports": {
    "#binding": {
      "darwin": {
        "arm64": "bare-collabora-darwin-arm64",
        "x64": "bare-collabora-darwin-x64"
      },
      "ios": {
        "arm64": {
          "simulator": "bare-collabora-ios-arm64-simulator",
          "default": "bare-collabora-ios-arm64"
        },
        "x64": {
          "simulator": "bare-collabora-ios-x64-simulator"
        }
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "binding.cc",
    "binding.js",
    "CMakeLists.txt",
    "lib",
    "prebuilds"
  ],
  "workspaces": [
    "npm/*"
  ],
  "addon": true,
  "scripts": {
    "format": "prettier --write . && lunte --fix",
    "lint": "prettier --check . && lunte",
    "test": "brittle-bare --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/bare-collabora.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/bare-collabora/issues"
  },
  "homepage": "https://github.com/holepunchto/bare-collabora#readme",
  "dependencies": {
    "bare-env": "^3.0.0",
    "bare-path": "^3.0.0",
    "bare-url": "^2.4.1"
  },
  "devDependencies": {
    "bare-lief": "^0.2.3",
    "brittle": "^3.1.1",
    "cmake-bare": "^1.8.0",
    "cmake-fetch": "^1.5.1",
    "cmake-ports": "^1.8.0",
    "lunte": "^1.6.0",
    "prettier": "^3.4.2",
    "prettier-config-holepunch": "^2.0.0"
  }
}
